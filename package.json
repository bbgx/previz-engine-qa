{
  "name": "validco",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --grep @ui",
    "test:api": "playwright test --grep @api",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "lint": "eslint tests/",
    "report": "playwright show-report",
    "test:a11y": "playwright test --grep @a11y",
    "test:visual": "playwright test --grep @visual",
    "test:visual:update": "playwright test --grep @visual --update-snapshots",
    "test:security": "playwright test --grep @security",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "allure:open": "allure open allure-report"
  },
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "allure-playwright": "^3.5.0",
    "eslint": "^10.0.2",
    "eslint-plugin-playwright": "^2.8.0",
    "typescript-eslint": "^8.56.1"
  }
}
